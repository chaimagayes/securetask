# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# PostgreSQL
POSTGRES_DB=securetask
POSTGRES_USER=securetask
POSTGRES_PASSWORD=change-me

# SQLAlchemy (note: this repo uses DATABASE_URI not DATABASE_URL)
# Keep this consistent with POSTGRES_* or let docker-compose set DATABASE_URI for the app container.
DATABASE_URI=postgresql://securetask:change-me@db:5432/securetask

# App image used by docker compose on EC2
APP_IMAGE=ghcr.io/chaimagayes/securetask:latest

# Gunicorn tuning (optional)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
