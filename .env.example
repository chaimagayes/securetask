# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# PostgreSQL
POSTGRES_DB=securetask
POSTGRES_USER=securetask
POSTGRES_PASSWORD=change-me

# SQLAlchemy (note: this repo uses DATABASE_URI not DATABASE_URL)
DATABASE_URI=postgresql://securetask:change-me@db:5432/securetask

# Gunicorn tuning (optional)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
